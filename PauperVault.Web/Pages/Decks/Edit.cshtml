@page "{id:guid}"
@model PauperVault.Web.Pages.Decks.EditModel
@using PauperVault.Web.Contracts.Decks
@using PauperVault.Core.Domain.Decks;

@{
    ViewData["Title"] = Model.Deck?.Name ?? "Éditer le deck";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h1 class="h2 mb-1">@Model.Deck.Name</h1>
            <p class="text-muted mb-0">Modifie les informations du deck et gère ses cartes.</p>
        </div>

        <a class="btn btn-outline-secondary" asp-page="/Decks/Index">Retour à mes decks</a>
    </div>

    <div class="row g-4">

        <!-- LEFT COLUMN -->
        <div class="col-12 col-lg-4">

            <!-- Deck infos -->
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Informations du deck</h2>

                    <form method="post" asp-page-handler="SaveDeck" class="vstack gap-3">

                        <div>
                            <label asp-for="DeckForm.Name" class="form-label"></label>
                            <input asp-for="DeckForm.Name" class="form-control" />
                            <span asp-validation-for="DeckForm.Name" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="DeckForm.Description" class="form-label"></label>
                            <textarea asp-for="DeckForm.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="DeckForm.Description" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark">
                            Enregistrer
                        </button>

                    </form>
                </div>
            </div>

            <!-- Add card -->
            <div class="card shadow-sm mt-4">
                <div class="card-body">

                    <h2 class="h5 mb-3">Ajouter une carte</h2>

                    <form method="post" asp-page-handler="AddCard" class="vstack gap-3">

                        <div class="position-relative">
                            <label asp-for="CardForm.CardName" class="form-label"></label>

                            <input asp-for="CardForm.CardName"
                                   class="form-control"
                                   id="cardSearch"
                                   autocomplete="off" />

                            <span asp-validation-for="CardForm.CardName"
                                  class="text-danger small"></span>

                            <div id="suggestions"
                                 class="list-group position-absolute w-100 shadow-sm"
                                 style="z-index:20; display:none;">
                            </div>
                        </div>

                        <div class="row g-2">

                            <div class="col-7">
                                <label asp-for="CardForm.Zone" class="form-label"></label>

                                <select asp-for="CardForm.Zone"
                                        class="form-select">

                                    <option value="@DeckZone.Main">
                                        Main
                                    </option>

                                    <option value="@DeckZone.Sideboard">
                                        Sideboard
                                    </option>

                                </select>
                            </div>

                            <div class="col-5">
                                <label asp-for="CardForm.Quantity" class="form-label"></label>

                                <input asp-for="CardForm.Quantity"
                                       class="form-control"
                                       type="number"
                                       min="1" />

                                <span asp-validation-for="CardForm.Quantity"
                                      class="text-danger small"></span>
                            </div>

                        </div>

                        <button type="submit" class="btn btn-dark">
                            Ajouter au deck
                        </button>

                    </form>

                </div>
            </div>
        </div>


        <!-- RIGHT COLUMN -->
        <div class="col-12 col-lg-8">

            <!-- MAIN DECK -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                    <h2 class="h4 mb-3">Main</h2>

                    @{
                        var mainCards = Model.Deck.Cards
                        .Where(x => x.Zone == DeckZone.Main)
                        .ToList();
                    }

                    @if (!mainCards.Any())
                    {
                        <p class="text-muted mb-0">
                            Aucune carte dans le main deck.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">

                            <table class="table align-middle mb-0">

                                <thead>
                                    <tr>
                                        <th style="width:100px;">Qté</th>
                                        <th>Carte</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    @foreach (var c in mainCards)
                                    {
                                        <tr>
                                            <td>@c.Quantity</td>
                                            <td>@c.Name</td>
                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>
                    }

                </div>
            </div>


            <!-- SIDEBOARD -->
            <div class="card shadow-sm">
                <div class="card-body">

                    <h2 class="h4 mb-3">Sideboard</h2>

                    @{
                        var sideCards = Model.Deck.Cards
                        .Where(x => x.Zone == DeckZone.Sideboard)
                        .ToList();
                    }

                    @if (!sideCards.Any())
                    {
                        <p class="text-muted mb-0">
                            Aucune carte dans le sideboard.
                        </p>
                    }
                    else
                    {
                        <div class="table-responsive">

                            <table class="table align-middle mb-0">

                                <thead>
                                    <tr>
                                        <th style="width:100px;">Qté</th>
                                        <th>Carte</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    @foreach (var c in sideCards)
                                    {
                                        <tr>
                                            <td>@c.Quantity</td>
                                            <td>@c.Name</td>
                                        </tr>
                                    }

                                </tbody>

                            </table>

                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>


@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        const input = document.getElementById("cardSearch");
        const suggestions = document.getElementById("suggestions");
        let timer = null;

        function hideSuggestions() {
            suggestions.style.display = "none";
            suggestions.innerHTML = "";
        }

        input.addEventListener("input", () => {

            const q = input.value.trim();

            if (q.length < 2) {
                hideSuggestions();
                return;
            }

            clearTimeout(timer);

            timer = setTimeout(async () => {

                const res = await fetch(`?handler=CardAutocomplete&q=${encodeURIComponent(q)}`);

                if (!res.ok) {
                    hideSuggestions();
                    return;
                }

                const data = await res.json();
                const items = data.suggestions || [];

                suggestions.innerHTML = "";

                if (!items.length) {
                    hideSuggestions();
                    return;
                }

                items.slice(0, 10).forEach(name => {

                    const btn = document.createElement("button");
                    btn.type = "button";
                    btn.className = "list-group-item list-group-item-action";
                    btn.textContent = name;

                    btn.addEventListener("click", () => {
                        input.value = name;
                        hideSuggestions();
                    });

                    suggestions.appendChild(btn);
                });

                suggestions.style.display = "block";

            }, 200);

        });

        document.addEventListener("click", (e) => {
            if (!suggestions.contains(e.target) && e.target !== input) {
                hideSuggestions();
            }
        });

    </script>
}