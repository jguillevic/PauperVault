@page
@model PauperVault.Web.Pages.Account.MeModel

@{
    ViewData["Title"] = "Mon compte";
}

<div class="container py-4">

    <div class="mb-4">
        <h1 class="h3 mb-1">Mon compte</h1>
        <p class="text-muted mb-0">Consultez les informations de votre profil.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @Model.ErrorMessage
        </div>
    }
    else if (Model.Me is null)
    {
        <div class="text-muted">
            Chargement des informations du compte...
        </div>
    }
    else
    {
        <!-- Card Profil -->
        <div class="card shadow-sm mb-3">
            <div class="card-body">

                <h2 class="h5 mb-3">Informations du profil</h2>

                <dl class="row mb-0">

                    <dt class="col-sm-3 text-muted">Identifiant</dt>
                    <dd class="col-sm-9">@Model.Me.UserId</dd>

                    <dt class="col-sm-3 text-muted">Adresse e-mail</dt>
                    <dd class="col-sm-9">@Model.Me.Email</dd>

                </dl>

            </div>
        </div>

        <!-- Card Activité -->
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Activité</h2>

                <p class="text-muted mb-3">
                    Retrouvez ici vos decks et statistiques lorsque ces fonctionnalités seront disponibles.
                </p>

                <div class="d-flex gap-2">
                    <a class="btn btn-outline-dark btn-sm" asp-page="/Decks/Index">
                        Voir mes decks
                    </a>

                    <a class="btn btn-outline-secondary btn-sm" asp-page="/Decks/Create">
                        Créer un deck
                    </a>
                </div>
            </div>
        </div>
    }

</div>